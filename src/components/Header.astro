---
import { Image } from "astro:assets";

import SkillIcon from "./SkillIcon.astro";
import Navbar from "./Navbar.astro";

import Me from "../assets/images/me.jpg";
import { skillIcons } from "../data/skill_icons_data";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
---

<header
  id="inicio"
  class="w-dvw h-dvh flex flex-col items-center justify-start bg-black"
>
  <Navbar pathname={pathname} />
  <div class="w-full h-[70%] flex flex-row">
    <div class="w-[70%] h-full flex flex-col justify-evenly items-center">
      <div class="w-[70%] h-[70%] flex flex-col justify-evenly items-stretch">
        <h1 class="font-display font-extrabold text-4xl text-white">
          Hola, mi nombre es Miguel Ángel<br />
          Chávez
        </h1>
        <p class="w-[80%] font-body font-extralight text-white">
          Llevo más de dos años desarrollando aplicaciones, en este tiempo he
          construido proyectos reales que abarcan el frontend, backend y
          desarrollo móvil. He pariticipado durante todo el proceso de
          desarrollo y ciclo de vida del software, desde el diseño hasta la
          implementación final.
        </p>
      </div>
    </div>
    <div class="w-[30%] h-full flex justify-center items-center">
      <Image
        alt={"Miguel Ángel Chávez Barrera"}
        src={Me}
        class="rounded-full w-48 aspect-square object-cover"
      />
    </div>
  </div>
  <div class="overflow-hidden w-full h-[10%]">
    <ul
      class="w-[200%] h-full animate-carousel flex items-center justify-evenly gap-1"
    >
      {
        skillIcons.map((skill) => (
          <SkillIcon
            iconName={skill.skillClassIcon}
            colored={skill.colored}
            shadowColor={skill.shadowColor}
          />
        ))
      }
    </ul>
  </div>
</header>
