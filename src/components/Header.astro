---
import { Image } from "astro:assets";
import SkillIcon from "./SkillIcon.astro";
import Me from "../assets/images/me.jpg";
---

<header
  class="w-full h-full bg-black flex flex-col items-center justify-center"
>
  <div class="w-full h-[70%] flex flex-row">
    <div class="w-[70%] h-full flex flex-col justify-evenly items-center">
      <div class="w-[70%] h-[70%] flex flex-col justify-evenly items-stretch">
        <h1 class="font-display font-extrabold text-4xl text-white">
          Hola, mi nombre es Miguel Ángel<br />
          Chávez
        </h1>
        <p class="w-[80%] font-body font-extralight text-white">
          Soy desarrollador de software Full Stack con experiencia en la construcción de
          aplicaciones web y móviles utilizando tecnologías modernas como Typescript, React,
          Node.js, React Native, Flutter, Express y PostgreSQL.
        </p>
        <button
          type="button"
          class="w-35 h-12.5
          text-white text-lg font-bold
            hover:cursor-pointer
          bg-green-500
            rounded-full
            shadow-2xl shadow-green-300/40 hover:shadow-green-300/70 transition-shadow duration-300"
        >
          Iniciemos
        </button>
      </div>
    </div>
    <div class="w-[30%] h-full flex justify-center items-center">
      <Image
        alt={"Miguel Ángel Chávez Barrera"}
        src={Me}
        class="rounded-full w-[50%] h-[50%] object-cover"
      />
    </div>
  </div>
  <div class="overflow-hidden w-full h-[10%]">
    <ul
      class="w-[200%] h-full animate-carousel flex items-center justify-evenly gap-1"
    >
      <SkillIcon iconName="devicon-html5-plain" colored />
      <SkillIcon iconName="devicon-css3-plain" colored />
      <SkillIcon iconName="devicon-javascript-plain" colored />
      <SkillIcon iconName="devicon-typescript-plain" colored />
      <SkillIcon iconName="devicon-react-original" colored />
      <SkillIcon iconName="devicon-tailwindcss-original" colored />
      <SkillIcon iconName="devicon-nodejs-plain-wordmark" colored />
      <SkillIcon iconName="devicon-express-original" colored />
      <SkillIcon iconName="devicon-postgresql-plain" colored />
      <SkillIcon iconName="devicon-mysql-plain" colored />
      <SkillIcon iconName="devicon-expo-line" colored={false} />
      <SkillIcon iconName="devicon-dart-plain" colored />
      <SkillIcon iconName="devicon-flutter-plain" colored />
      <SkillIcon iconName="devicon-zustand-plain" colored={false} />
      <SkillIcon iconName="devicon-html5-plain" colored />
      <SkillIcon iconName="devicon-css3-plain" colored />
      <SkillIcon iconName="devicon-javascript-plain" colored />
      <SkillIcon iconName="devicon-typescript-plain" colored />
      <SkillIcon iconName="devicon-react-original" colored />
      <SkillIcon iconName="devicon-tailwindcss-original" colored />
      <SkillIcon iconName="devicon-nodejs-plain-wordmark" colored />
      <SkillIcon iconName="devicon-express-original" colored />
      <SkillIcon iconName="devicon-postgresql-plain" colored />
      <SkillIcon iconName="devicon-mysql-plain" colored />
      <SkillIcon iconName="devicon-expo-line" colored={false} />
      <SkillIcon iconName="devicon-dart-plain" colored />
      <SkillIcon iconName="devicon-flutter-plain" colored />
      <SkillIcon iconName="devicon-zustand-plain" colored={false} />
    </ul>
  </div>
</header>
