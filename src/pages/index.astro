---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SkillCard from "../components/SkillCard.astro";
import Carousel from "../components/Carousel.astro";

const pathname = Astro.url.pathname;
---

<Layout>
  <Header pathname={pathname} />
  <main class="w-full flex flex-col">
    <section id="skills" class="px-4 py-8">
      <div class="flex flex-col max-w-7xl mx-auto">
        <h1 class="text-white font-display text-2xl mb-2">Skills</h1>
        <p
          class="text-justify text-white font-body font-extralight mb-6
                 w-full sm:w-4/5 md:w-3/4 lg:w-2/3"
        >
          Estas son las tecnologías con las que trabajo en el día a día. A lo
          largo de mi carrera como ingeniero y desarrollador de sistemas de
          información, he construido proyectos reales con cada una de ellas,
          desde interfaces de usuario hasta APIs y bases de datos.
        </p>

        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4"
        >
          <SkillCard
            cardTitle="Fundamentals"
            skills={[
              { name: "Object Oriented Programming (OOP)" },
              { name: "Data Structures (I, II)" },
            ]}
          />
          <SkillCard
            cardTitle="Frontend"
            skills={[
              { name: "First mobile" },
              { name: "Clean Architecture" },
              { name: "API integration" },
              { name: "HTML", icon: "devicon-html5-plain" },
              { name: "CSS", icon: "devicon-css3-plain" },
              { name: "JavaScript", icon: "devicon-javascript-plain" },
              { name: "TypeScript", icon: "devicon-typescript-plain" },
              { name: "React", icon: "devicon-react-original" },
              { name: "TailwindCSS", icon: "devicon-tailwindcss-original" },
              { name: "Zustand", icon: "devicon-javascript-plain" },
            ]}
          />
          <SkillCard
            cardTitle="Backend"
            skills={[
              { name: "Layered Architecture" },
              { name: "REST API" },
              { name: "NodeJS", icon: "devicon-nodejs-plain-wordmark" },
              { name: "ExpressJS", icon: "devicon-express-original" },
            ]}
          />
          <SkillCard
            cardTitle="Mobile"
            skills={[
              { name: "React Native", icon: "devicon-reactnative-original" },
              { name: "EXPO", icon: "devicon-expo-line" },
              { name: "Dart", icon: "devicon-dart-plain" },
              { name: "Flutter Mobile", icon: "devicon-flutter-plain" },
            ]}
          />
          <SkillCard
            cardTitle="Database"
            skills={[
              { name: "Database design" },
              { name: "Database management" },
              { name: "MySQL", icon: "devicon-mysql-plain" },
              { name: "PostgreSQL", icon: "devicon-postgresql-plain" },
            ]}
          />
          <SkillCard
            cardTitle="Language"
            skills={[{ name: "Spanish - Native" }, { name: "English - B2" }]}
          />
        </div>
      </div>
    </section>

    <section id="projects" class="w-full min-h-screen px-4 py-8">
      <div class="max-w-7xl mx-auto flex flex-col gap-6">
        <div class="w-full lg:w-1/2">
          <h1 class="font-display text-2xl text-white mb-3">Proyectos</h1>
          <p class="font-body font-extralight text-white">
            <strong>Miracles CMS</strong> es el proyecto fullstack el cual dispone
            de un gestor de contenido para comercios, en donde se puede realizar la
            gestión de usuario, categorías, productos y configuración de estilos del
            ecommerce en donde se carga todo el catálogo de un comercio.
          </p>
        </div>

        <div class="w-full lg:w-1/2">
          <p class="font-body font-extralight text-white mb-4">
            Las tecnologías que se usaron para desarrollar este proyecto en cada
            una de sus capas fueron las siguientes:
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <h2 class="font-display text-xl text-white mb-2">Frontend</h2>
              <ul
                class="list-disc ml-6 font-body font-extralight text-white space-y-1"
              >
                <li>Vite</li>
                <li>TypeScript</li>
                <li>React</li>
                <li>TailwindCSS</li>
                <li>React Hook Form</li>
                <li>AXIOS</li>
              </ul>
            </div>

            <div>
              <h2 class="font-display text-xl text-white mb-2">Backend</h2>
              <ul
                class="list-disc ml-6 font-body font-extralight text-white space-y-1"
              >
                <li>NodeJS</li>
                <li>ExpressJS</li>
              </ul>
            </div>

            <div>
              <h2 class="font-display text-xl text-white mb-2">
                Base de datos
              </h2>
              <ul
                class="list-disc ml-6 font-body font-extralight text-white space-y-1"
              >
                <li>PostgreSQL</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="w-full flex justify-center">
          <Carousel />
        </div>
      </div>
    </section>
  </main>
</Layout>
