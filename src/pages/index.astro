---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SkillCard from "../components/SkillCard.astro";
import Carousel from "../components/Carousel.astro";

const pathname = Astro.url.pathname;
---

<Layout>
  <Header pathname={pathname} />
  <section class="w-dvw h-dvh">
    <div class="flex flex-col">
      <h1 class="text-white font-display text-2xl ml-3">Skills</h1>
      <p class="text-white font-body font-extralight ml-3 w-[50%]">
        Estas son las tecnologías con las que trabajo en el día a día. A lo
        largo de mi carrera como ingeniero y desarrollador de sistemas de
        información, he construido proyectos reales con cada una de ellas, desde
        interfaces de usuario hasta APIs y bases de datos.
      </p>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 p-7 mt-3"
      >
        <SkillCard
          cardTitle="Fundamentals"
          skills={[
            { name: "Object Oriented Programming (OOP)" },
            { name: "Data Structures (I, II)" },
          ]}
        />
        <SkillCard
          cardTitle="Fronted"
          skills={[
            { name: "First mobile" },
            { name: "Clean Architecture" },
            { name: "API integration" },
            { name: "HTML", icon: "devicon-html5-plain" },
            { name: "CSS", icon: "devicon-css3-plain" },
            { name: "JavaScript", icon: "devicon-javascript-plain" },
            { name: "TypeScript", icon: "devicon-typescript-plain" },
            { name: "React", icon: "devicon-react-original" },
            { name: "TailwindCSS", icon: "devicon-tailwindcss-original" },
            { name: "Zustand", icon: "devicon-javascript-plain" },
          ]}
        />
        <SkillCard
          cardTitle="Backend"
          skills={[
            { name: "Layred Architecture" },
            { name: "REST API" },
            { name: "NodeJS", icon: "devicon-nodejs-plain-wordmark" },
            { name: "ExpressJS", icon: "devicon-express-original" },
          ]}
        />
        <SkillCard
          cardTitle="Mobile"
          skills={[
            { name: "React Native", icon: "devicon-reactnative-original" },
            { name: "EXPO", icon: "devicon-expo-line" },
            { name: "Dart", icon: "devicon-dart-plain" },
            { name: "Flutter Mobile", icon: "devicon-flutter-plain" },
          ]}
        />
        <SkillCard
          cardTitle="Database"
          skills={[
            { name: "Database design" },
            { name: "Database management" },
            { name: "MySQL", icon: "devicon-mysql-plain" },
            { name: "PostgreSQL", icon: "devicon-postgresql-plain" },
          ]}
        />
        <SkillCard
          cardTitle="Language"
          skills={[{ name: "Spanish - Native" }, { name: "English - B2" }]}
        />
      </div>
    </div>
  </section>
  <section class="w-dvw h-dvh">
    <div class="flex w-full">
      <div class="w-[50%]">
        <h1 class="font-display text-2xl text-white ml-3">Proyectos</h1>
        <p class="font-body font-extralight text-white ml-3">
          <strong>Miracles CMS</strong> es el proyecto fullstack el cual dispone de
          un gestor de contenido para comercios, en donde se puede realizar la gestión
          de usuario, categorías, productos y configuración de estilos del ecommerce
          en donde se carga todo el cátalogo de un comercio.
        </p>
      </div>
      <div class="w-[50%]"></div>
    </div>
    <br />
    <div class="flex flex-col w-[50%] ml-3">
      <p class="font-body font-extralight text-white">
        Las tecnologías que se usaron para desarrollar este proyecto en cada una
        de sus capas fueron las siguientes:
      </p>

      <br />

      <h2 class="font-display text-2xl text-white">Fronted</h2>
      <ul class="list-disc w-[50%] ml-10 font-body font-extralight text-white">
        <li>Vite</li>
        <li>TypeScript</li>
        <li>React</li>
        <li>TailwindCSS</li>
        <li>React Hook Form</li>
        <li>AXIOS</li>
      </ul>

      <br />

      <h2 class="font-display text-2xl text-white">Backend</h2>
      <ul class="list-disc w-[50%] ml-10 font-body font-extralight text-white">
        <li>NodeJS</li>
        <li>ExpressJS</li>
      </ul>
      <h2 class="font-display text-2xl text-white">Base de datos</h2>
      <ul class="list-disc w-[50%] ml-10 font-body font-extralight text-white">
        <li>PostgreSQL</li>
      </ul>
    </div>
    <div class="w-full h-full flex justify-center">
      <Carousel />
    </div>
  </section>
  <footer class="w-dvw h-[20%]"></footer>
</Layout>
